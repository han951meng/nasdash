appname               = com.dashboard.nasdash
version               = 1.5.0
display_name          = NAS硬件监控
desc                  = <p>飞牛OS 硬件监控面板，可视化查看 NAS 硬件状态，免去 SSH 敲命令。</p><p>自动识别阵列卡类型：MegaRAID 卡显示型号 / 固件 / CacheVault / 物理盘列表及芯片温度（ROC Temperature）；HBA 直通卡（IT 模式）内联显示每块盘温度；纯 SATA 主板给出提示。阵列卡标签页统一显示「模式 / 状态 / 说明」，并新增「硬件配置检测」首页（单页仪表盘：顶部状态栏实时概览 + 系统配置 + 阵列卡&磁盘 + 存储卷）。</p><p>四个标签页：阵列卡 / 硬盘 SMART / 系统资源（CPU·内存·温度·风扇·电压·显卡·网卡）/ 存储卷。</p><p>安装时自动安装依赖（smartmontools、lm-sensors、mdadm、Flask）；LSI MegaRAID 卡需另装 storcli，HBA 直通卡与纯 SATA 主板无需 storcli。</p>
platform              = x86
source                = thirdparty
maintainer            = nasdash
distributor           = nasdash
service_port          = 9800
checkport             = true
os_min_version        = 0.9.0
desktop_uidir         = ui
desktop_applaunchname = com.dashboard.nasdash.main
ctl_stop              = true
install_type          = root
changelog             = 1.5.0: 新增「硬件配置检测」首页模块（ardot设计稿单页仪表盘），含顶部状态栏(风扇/阵列卡/硬盘/Docker实时状态)、系统配置卡片(CPU+内存)、阵列卡&磁盘合并面板、存储卷表；后端新增Docker容器数采集(sudo docker ps)；左侧边栏导航新增首项并默认选中
