appname               = com.dashboard.nasdash
version               = 1.8.4
display_name          = NAS硬件监控
desc                  = <p><b>飞牛OS 硬件监控面板</b> —— 可视化查看 NAS 硬件状态，免去 SSH 敲命令。</p><p><b>功能模块</b></p><ul><li><b>硬件配置检测</b>：单页仪表盘，含顶部状态栏 + 系统配置（CPU / 显卡 / 主板 / 内存条品牌型号 / 运行时间 / 网络含实时↓收↑发速率）+ 阵列卡与磁盘概览</li><li><b>阵列卡</b>：自动识别卡类型，显示型号 / 模式 / 芯片温度与物理盘列表（品牌识别准确）</li><li><b>硬盘 SMART</b>：每块盘健康、温度、转速、品牌、容量与型号</li><li><b>系统资源</b>：负载 / 内存 / 温度 / 风扇转速 / 电压 / 磁盘 I/O（每盘读写为实时速率）+ 历史趋势图（24h/7d/30d）</li><li><b>风扇控制</b>：预设档调速 + 实时 RPM/占空比；每风扇自定义名称与电压；两套独立温控（硬盘/主板CPU）；<b>曲线编辑器</b>自定义温度→PWM + 静音/均衡/性能预设；<b>系统风扇服务安全接管</b>：接管风扇时自动停止 pwm-fancontrol、全部交还自动温控后自动重启，规避抢写 PWM 冲突；面板内置一键永久禁用/恢复</li><li><b>存储卷</b>：mdadm 软阵列</li><li><b>Docker</b>：容器状态、内存(字节/百分比)、CPU%、网络RX/TX、端口映射、运行时长</li><li><b>控制与自动化</b>：温度/硬盘健康告警（面板提示 + 可选 Telegram/Bark/邮件）+ 一键 JSON/HTML 健康报告</li><li><b>主板型号标注</b> / <b>内存品牌</b>(SPD直读) / <b>版本自检</b>(面板显示当前/最新)</li></ul><p><b>依赖说明</b></p><p>安装时自动安装：smartmontools、lm-sensors、mdadm、Flask、dmidecode、i2c-tools。<br><b>storcli 现已随包内置</b>：MegaRAID 卡与 HBA 直通卡用户无需再从 Broadcom 官网手动下载，安装即自动落地到 /opt/MegaRAID/storcli。</p>
platform              = x86
source                = thirdparty
maintainer            = han951meng
distributor           = han951meng
maintainer_url         = https://github.com/han951meng
distributor_url        = https://github.com/han951meng
os_min_version        = 0.9.0
desktop_uidir         = ui
desktop_applaunchname = com.dashboard.nasdash.main
ctl_stop              = true
; 统一网关模式：声明 service_port=9800（仅 127.0.0.1 监听，不对外暴露），
; 飞牛 appcenter 会为本应用创建 gateway/sac 入口，网关/应用中心均可用此端口。
; 同时保留 gatewaySocket=app.sock，应用中心也靠它判断应用已就绪。
service_port          = 9800
checkport             = false
disable_authorization_path = true
changelog             = 1.8.4: 移动端适配(抽屉式导航+宽表横向滚动)与风扇页硬盘名称竖排堆叠显示修复 1.8.3: 移动端适配：左侧导航改为可隐藏抽屉式（汉堡菜单+遮罩），阵列卡/风扇控制/Docker 等页面的宽表格改为横向滚动而非撑破页面，手机上不再需要拖动查看全部内容 1.8.2: 性能优化：切换导航只刷新当前板块，重型采集(阵列卡/SMART)加缓存，大幅减少全量刷新卡顿
