ctl_stop              = true
; 统一网关模式：声明 service_port=9800（仅 127.0.0.1 监听，不对外暴露），
; 飞牛 appcenter 会为本应用创建 gateway/sac 入口，网关/应用中心均可用此端口。
; 同时保留 gatewaySocket=app.sock，应用中心也靠它判断应用已就绪。
service_port          = 9800
checkport             = false
disable_authorization_path = true
