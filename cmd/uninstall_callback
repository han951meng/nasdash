#!/bin/bash
# 卸载后回调：镜像用户配置到持久目录双保险 + 清理进程
# 注意：自 v1.7.12 起，风扇/主板标注等用户配置由 app.py 直接写入 TRIM_PKGVAR（@appdata，
# 卸载后保留），已天然重装不丢。此处仅再镜像一份到 config_backup 目录双保险。
: "${TRIM_PKGVAR:=/usr/local/apps/@appdata/com.dashboard.nasdash}"
mkdir -p "$TRIM_PKGVAR/config_backup"
for f in fan_disk_temp.json fan_sys_temp.json fan_labels.json board_override.txt; do
    if [ -f "$TRIM_PKGVAR/$f" ]; then
        cp -f "$TRIM_PKGVAR/$f" "$TRIM_PKGVAR/config_backup/$f"
        echo "[nasdash] 已镜像用户配置 $f" >> "${TRIM_TEMP_LOGFILE}"
    fi
done

PID_FILE="${TRIM_PKGVAR}/app.pid"
if [ -f "$PID_FILE" ]; then
    pid=$(cat "$PID_FILE" | tr -d '[:space:]')
    [ -n "$pid" ] && kill "$pid" 2>/dev/null
    rm -f "$PID_FILE"
fi
exit 0
