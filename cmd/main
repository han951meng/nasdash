#!/bin/bash
PID_FILE="${TRIM_PKGVAR}/app.pid"
APP_DIR="${TRIM_APPDEST}"
# 飞牛网关把 ui/config 的 gatewaySocket 相对【应用根目录】解析，而非 target/ 子目录。
# fygo-browser(/vol1/@appcenter/fygo-browser/app.sock)、
# Hermes(/vol1/@appcenter/trim.hermes/run/trim-hermes.sock) 均把 socket 建在根目录内。
# 应用根目录 = 含 cmd/ 与 ui/ 的那一层。TRIM_APPDEST 通常即根目录；
# 个别版本可能指向 target/ 子目录，此时根为其父目录。
if [ -d "$APP_DIR/../cmd" ] && [ -d "$APP_DIR/../ui" ]; then
    # TRIM_APPDEST 指向 target/ 子目录，根是父目录
    APP_ROOT="$(cd "$APP_DIR/.." && pwd)"
else
    APP_ROOT="$APP_DIR"
fi
PYTHON=$(which python3 2>/dev/null || echo "/usr/bin/python3")
LOG_FILE="${TRIM_PKGVAR}/app.log"

# 飞牛统一网关的上游 socket 路径登记在 PostgreSQL trim_sac.entry 表(gateway_socket 字段)。
# nasdash 该记录早期(ui/config 尚未配好 gatewaySocket 时)建立，之后每次重装走 UPDATE 分支，
# appcenter 不再重算该字段 -> gateway_socket 长期为空 -> 网关收到登录态请求后找不到上游 -> 404。
# 自愈：每次启动把此字段补正确；仅当确有变更时才重启网关进程使其重载(幂等，已正确则零打扰)。
# 本函数绝不阻断应用启动：任何失败仅记日志后返回。
self_heal_gateway() {
    local SOCK_TARGET="/var/apps/com.dashboard.nasdash/target/app.sock"
    local PREFIX="/app/com.dashboard.nasdash"
    local HEAL_LOG="${TRIM_PKGVAR:-/var/apps/com.dashboard.nasdash/var}/gateway_heal.log"
    local PSQL_BIN
    PSQL_BIN="$(command -v psql 2>/dev/null || echo /usr/bin/psql)"
    [ -x "$PSQL_BIN" ] || { echo "$(date '+%F %T') psql not found, skip gateway heal" >> "$HEAL_LOG"; return 0; }
    # 先查是否已正确：避免把 psql 的 "UPDATE 0" 命令标签误判为“已变更”而冗余重启网关。
    local ok
    ok=$(sudo -u postgres "$PSQL_BIN" -d trim_sac -tAc \
        "SELECT 1 FROM entry WHERE app_name='com.dashboard.nasdash' \
           AND gateway_socket='$SOCK_TARGET' AND gateway_prefix='$PREFIX' LIMIT 1;" 2>/dev/null)
    if [ "$ok" = "1" ]; then
        return 0   # 已正确：零打扰、不写日志、不重启网关
    fi
    # 需要修复：写回正确 socket 并重启网关使其从库重载入口(勿用 kill -HUP，会直接杀掉该进程)。
    sudo -u postgres "$PSQL_BIN" -d trim_sac -c \
        "UPDATE entry SET gateway_socket='$SOCK_TARGET', gateway_prefix='$PREFIX' \
         WHERE app_name='com.dashboard.nasdash';" >> "$HEAL_LOG" 2>&1
    echo "$(date '+%F %T') gateway entry fixed (was empty/recreated), restarting trim_http_cgi" >> "$HEAL_LOG"
    systemctl restart trim_http_cgi >> "$HEAL_LOG" 2>&1 || \
        echo "$(date '+%F %T') WARN: systemctl restart trim_http_cgi failed" >> "$HEAL_LOG"
    return 0
}

# 常驻看门狗：以 setsid 分离启动独立的 gw_watchdog.sh（不依赖本 shell 存活），
# 每 30s(及启动时立即)校验 entry，若被 appcenter 重建/清空则自动补回。按进程名判断是否已在运行。
launch_watchdog() {
    local WD="$APP_DIR/../cmd/gw_watchdog.sh"
    [ -x "$WD" ] || WD="/var/apps/com.dashboard.nasdash/cmd/gw_watchdog.sh"
    [ -f "$WD" ] || return 0
    # 已存在运行中的看门狗进程则不重复启动(按进程名判断，比 pidfile 可靠，避免陈旧 pid 误判)
    if ps -ef 2>/dev/null | grep -q "[g]w_watchdog.sh"; then
        return 0
    fi
    setsid bash "$WD" </dev/null >/dev/null 2>&1 &
    echo $! > "${TRIM_PKGVAR:-/var/apps/com.dashboard.nasdash/var}/gw_watchdog.pid"
}

case $1 in
start)
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE" | tr -d '[:space:]')
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            # 已在运行：仍执行网关自愈(幂等)，防止 entry 被清空后下次网关重启导致 404。
            self_heal_gateway
            launch_watchdog
            echo "应用已在运行 (PID: $pid)" > "${TRIM_TEMP_LOGFILE}"
            exit 0
        fi
        rm -f "$PID_FILE"
    fi
    # 自愈：飞牛靠 /app/app.py 软链做启动/健康检；uninstall 会删掉它而 install 不重建，
    # 不补则 start 必报 10500。cmd/main 以 root 运行，此处自动重建软链。
    if [ -f "$APP_DIR/app.py" ]; then
        mkdir -p /app 2>/dev/null
        ln -sf "$APP_DIR/app.py" /app/app.py 2>/dev/null
    fi
    # 加载风扇控制芯片驱动（按需，缺则忽略）：
    # 新机(MSI B360M MORTAR)=NCT6797D 走 nct6775；旧机=IT87 走 it87。
    # fnOS 默认不加载，须由 app 自启恢复风扇可见性。
    modprobe nct6775 2>/dev/null || true
    modprobe it87 2>/dev/null || true
    cd "$APP_DIR"
    # 统一网关模式：监听 Unix Socket（飞牛网关校验登录态后转发），不再暴露裸 TCP 端口。
    # socket 建在应用根目录 APP_ROOT/app.sock（飞牛网关按根目录解析 gatewaySocket=app.sock）。
    rm -f "$APP_ROOT/app.sock" 2>/dev/null
    export NAS_DASH_GATEWAY=1
    export GATEWAY_PREFIX="/app/com.dashboard.nasdash"
    export APP_SOCKET="$APP_ROOT/app.sock"
    # 启动 app 前先自愈网关入口：飞牛 start 超时报 10500 时会杀掉本进程，
    # 若把自愈放在轮询 socket 之后可能来不及执行。网关惰性连上游，先修 DB+重载网关，
    # 等下方 app 起来、socket 就绪后用户点击即可连上。
    self_heal_gateway
    $PYTHON "$APP_DIR/app.py" > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    # 轮询等待 app.sock 真正建立再返回：飞牛 appcenter 会在 start 后探测 gateway socket，
    # 若 socket 尚未就绪（app.py 导入 Flask/注册路由需数秒）会跳过网关入口创建 -> 404。
    # 等到 socket 出现可让 appcenter 稳定探测到，从而正确注册 /app/{appname} 路由。
    SOCK="$APP_ROOT/app.sock"
    for i in $(seq 1 30); do
        if [ -S "$SOCK" ]; then
            break
        fi
        sleep 0.5
    done
    if kill -0 "$(cat "$PID_FILE" | tr -d '[:space:]')" 2>/dev/null; then
        # 应用已就绪：自愈网关入口(幂等，不阻断启动)。
        self_heal_gateway
        # 启动常驻看门狗(防 appcenter 在运行期回滚 gateway_socket)；已存在则跳过。
        launch_watchdog
        exit 0
    else
        echo "应用启动失败，请查看日志: $LOG_FILE" > "${TRIM_TEMP_LOGFILE}"
        rm -f "$PID_FILE"
        exit 1
    fi
    ;;
stop)
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE" | tr -d '[:space:]')
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null
            sleep 1
            kill -9 "$pid" 2>/dev/null
        fi
        rm -f "$PID_FILE"
    fi
    exit 0
    ;;
status)
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE" | tr -d '[:space:]')
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            exit 0
        fi
        rm -f "$PID_FILE"
    fi
    exit 3
    ;;
*)
    exit 1
    ;;
esac
